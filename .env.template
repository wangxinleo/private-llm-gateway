# Privacy Proxy Environment Configuration
# Copy this to .env only for direct npm runs. docker-compose.yaml keeps its
# essential startup values inline so deployments can edit that file directly.
# Never commit .env with secrets.

NODE_ENV=production
PORT=3000
HOSTNAME=0.0.0.0
DEBUG=false

# Upstream service that this proxy forwards to.
UPSTREAM_URL=http://localhost:8787

# SQLite audit database path for direct npm runs.
DB_PATH=audit.sqlite

# Admin key required to access /dashboard management console.
# Generate a strong random key: openssl rand -base64 32
ADMIN_KEY=
