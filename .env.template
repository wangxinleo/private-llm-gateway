# ========================================
# Privacy Proxy Environment Configuration
# ========================================
# Copy this to .env and fill in your values.
# Never commit .env with secrets.

# ========================================
# Core Configuration
# ========================================

# Node environment (production/development)
NODE_ENV=production

# Port the Next.js server listens on inside the container
PORT=3000

# Hostname/interface to bind to (0.0.0.0 for Docker)
HOSTNAME=0.0.0.0

# Debug mode (true to show detailed logs, false for production)
# Default: false in production, true in development
DEBUG=false

# Timezone for container processes and log timestamps
TZ=Asia/Shanghai

# ========================================
# Docker Compose Only
# ========================================

# Port to expose on the Docker host (maps to container PORT)
HOST_PORT=3000

# ========================================
# Upstream Service
# ========================================

# URL to the upstream service that this proxy forwards to
# - If the upstream is a Compose service in the same network: http://upstream-service:8787
# - If the upstream runs on host machine (Docker Desktop): http://host.docker.internal:8787
UPSTREAM_URL=http://upstream-service:8787

# ========================================
# Database
# ========================================

# Path to SQLite audit database inside container
# Data persists via bind mount ./data:/data
DB_PATH=/data/audit.sqlite
