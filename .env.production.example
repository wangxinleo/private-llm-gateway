# Public listen port on the Docker host.
PRIVACY_PROXY_PORT=3000

# Container listen port. Keep this at 3000 unless the Dockerfile changes.
PRIVACY_PROXY_CONTAINER_PORT=3000

# Upstream ccload base URL from inside the Docker network.
# If ccload is another Compose service, keep http://ccload:8787.
# If ccload runs on the host machine, use http://host.docker.internal:8787 on Docker Desktop.
PRIVACY_PROXY_CCLOAD_URL=http://ccload:8787

# Persist audit metadata outside the application directory.
PRIVACY_PROXY_DB_PATH=/data/audit.sqlite
